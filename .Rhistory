### find out which sites most disagreeable
survey_ca <- abs(survey_t-ca_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","Survey & CA"))
survey_upda <- abs(survey_t-upda_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","Survey & UPDA"))
survey_vep <- abs(survey_t-vep_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","Survey & VEP"))
ca_upda <- abs(ca_t-upda_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","CA & UPDA"))
ca_vep <- abs(ca_t-vep_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","CA & VEP"))
upda_vep <- abs(upda_t-vep_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","UPDA & VEP"))
all_list <- list(survey_ca,survey_upda,survey_vep,ca_upda,ca_vep,upda_vep)
all_disagreement_site <- all_list%>%
reduce(left_join,by="Site.Number")%>%
rowwise()%>%
mutate(`Mean Across Methods` = mean(c_across(survey_ca:upda_vep)))%>%
ungroup()%>%
gather(method,value,-Site.Number)
all_disagreement_site <- all_list%>%
reduce(left_join,by="Site.Number")%>%
rowwise()
View(all_disagreement_site)
