ca_multi <- ca %>%
mutate(across(everything(), ~ if_else(. > 0, 1, 0)))
View(ca_multi)
vep_multi <- vep %>%
mutate(across(everything(), ~ if_else(. > 0, 1, 0)))
View(vep_multi)
ca_multi <- ca %>%
mutate(across(-Site.Number, ~ if_else(. > 0, 1, 0)))
View(ca)
ca_multi <- ca%>%
rownames_to_column(var = "Site.Number")%>%
mutate(across(-Site.Number, ~ if_else(. > 0, 1, 0)))
vep_multi <- vep %>%
mutate(across(-Site.Number, ~ if_else(. > 0, 1, 0)))
ca_multi$num_groups <- apply(ca_multi, 1, function(x) {
r <- rle(x)
sum(r$values == 1)
})
View(ca_multi)
vep_multi$num_groups <- apply(vep_multi, 1, function(x) {
r <- rle(x)
sum(r$values == 1)
