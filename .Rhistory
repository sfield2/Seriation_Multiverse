### find out which sites most disagreeable
survey_ca <- abs(survey_t-ca_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","survey_ca"))
survey_upda <- abs(survey_t-upda_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","survey_upda"))
survey_vep <- abs(survey_t-vep_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","survey_vep"))
ca_upda <- abs(ca_t-upda_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","ca_upda"))
ca_vep <- abs(ca_t-vep_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","ca_vep"))
upda_vep <- abs(upda_t-vep_t)%>%
select(-c("Year"))%>%
t()%>%
as.data.frame()%>%
mutate(sums=rowSums(across(where(is.numeric)),na.rm=T))%>%
select(c(sums))%>%
rownames_to_column(var="Site.Number")%>%
setNames(c("Site.Number","upda_vep"))
all_list <- list(survey_ca,survey_upda,survey_vep,ca_upda,ca_vep,upda_vep)
all_disagreement_site <- all_list%>%
reduce(left_join,by="Site.Number")%>%
rowwise()%>%
mutate(mean_disagreement = mean(c_across(survey_ca:upda_vep)))%>%
ungroup()
most_disagreeable_sites <- filter(all_disagreement_site,mean_disagreement>200)
all_dis <- all_disagreement_site%>%
gather(method,value,-Site.Number)
all_dis$method <- factor(all_dis$method,levels=c("mean_disagreement","survey_ca","survey_upda","survey_vep","ca_upda","ca_vep","upda_vep"))
most_dis <- filter(all_dis,Site.Number %in% most_disagreeable_sites$Site.Number)
ggplot()+
geom_density_ridges(data=all_dis,aes(x=value,y=method,color=method,fill=method))
geom_vline(data=most_dis,aes(xintercept=value,group=method))+
facet_wrap(~method)
